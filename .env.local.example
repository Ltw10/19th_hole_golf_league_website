# Supabase — expose schema `nhgl` in Project Settings → API → Exposed schemas
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin moderation (API + server actions). Use a long random string.
NHGL_ADMIN_SECRET=change_me_to_a_long_random_secret

# Optional: IANA timezone for "current week" on the schedule (default America/New_York Eastern).
# NHGL_LEAGUE_TIMEZONE=America/New_York

# Optional: enable Supabase debug logs + GET /api/debug/db when not in dev (e.g. `next start`)
# DEBUG_SUPABASE=1

# Client + server: turn on [nhgl] console logs and /api/debug/db if `npm run dev` shows nothing (e.g. wrong terminal)
# NEXT_PUBLIC_NHGL_DEBUG=1
